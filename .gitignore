# ── 1. Python & Bytecode ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── 2. Active Virtual Memory & Paging Cache (paging_kernel.py) ───────────────
# Ignores ephemeral JSON block caches while allowing the directory structure
/offload_store/
!/offload_store/.keep
/global_cache/

# ── 3. Checkpoints, Snapshots & State Resurrection (checkpoint.py) ───────────
.pipeline_checkpoints/
.pipeline_snapshots/
*.snapshot.pickle
*.state.json

# ── 4. Dynamic Math Analyst Subprocess Artifacts (mesh_loops.py) ─────────────
# Solvers compiled natively during Phase 4 numerical verification runs
/global_cache/math_analyst/
solver_*.py

# ── 5. Ephemeral Session Outputs & Backups ───────────────────────────────────
pipeline_output_*.md
pipeline_inventory.json
*.bkup_*
*.old
*.tmp
*.bak
.migration_manifest.json

# ── 6. Dynamic Adversarial TDD Test Artifacts ────────────────────────────────
# Ignore dynamic unit tests generated by the Test Architect during execution waves,
# but STRICTLY track foundational characterization tests (test_*.py)
/tests/test_task_*.lua
/tests/test_task_*.cpp
/tests/test_task_*.cxx
/tests/test_task_*.py
/tests/test_sub_*.lua
/tests/test_sub_*.cpp

# ── 7. OS & Environment Clutter ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── 8. IDE & Local Tooling ───────────────────────────────────────────────────
.vscode/
.idea/
.vs/
*.swp
*.suo
